# Copy this file to the repo root as `.env.deploy` and fill in values.
# `.env.deploy` is gitignored — never commit real hostnames or secrets.

# SSH target: user@host or an alias from ~/.ssh/config (e.g. my-sermon-server)
DEPLOY_SSH=ec2-user@YOUR_EC2_PUBLIC_IP

# Absolute path to this repo on the Linux server
DEPLOY_APP_DIR=/home/ec2-user/ser

# Optional (default: main)
# DEPLOY_GIT_BRANCH=main

# Optional: if you use PM2, set the process name from `pm2 list`
# PM2_APP_NAME=sermon-generator
